---
import heroLogo from "../assets/hero_logo.webp";
---

<section class="max-w-screen-2xl mx-auto px-6" data-view="main">
  <div class="mt-6 flex justify-center md:justify-end">
    <img
      src={heroLogo.src}
      alt="MTGA Artisan Logo"
      width={350}
      height={246}
      class="w-auto h-[246px]"
    />
  </div>
  <div class="flex md:hidden gap-4 mb-8">
    <button type="button" class="tab-button" data-view-btn="main">
      Articles
    </button>
    <button type="button" class="tab-button" data-view-btn="aside">
      Topics
    </button>
  </div>
  <div class="md:grid md:grid-cols-5 md:gap-8">
    <div class="md:col-span-4" data-panel="main">
      <slot name="main" />
    </div>
    <aside
      class="md:col-span-1 md:flex md:flex-col md:gap-4"
      data-panel="aside"
    >
      <slot name="topic-list" />
    </aside>
  </div>
</section>

<style>
  .tab-button {
    border: 1px solid var(--color-primary);
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    color: var(--color-text);
    background: transparent;
    transition: all 0.2s ease-in-out;
  }

  .tab-button.is-active {
    background: var(--color-primary);
    color: #fff;
    box-shadow: 0 0 12px rgba(255, 80, 80, 0.35);
  }

  section[data-view="main"] [data-panel="aside"] {
    display: none;
  }

  section[data-view="aside"] [data-panel="main"] {
    display: none;
  }

  @media (min-width: 768px) {
    section[data-view] [data-panel="main"] {
      display: block;
    }

    section[data-view] [data-panel="aside"] {
      display: flex;
    }

    .tab-button {
      display: none;
    }
  }
</style>

<script>
  const initTabs = () => {
    const section = document.querySelector("section[data-view]");
    if (!section) return;

    const buttons = section.querySelectorAll("[data-view-btn]");
    let currentView = section.getAttribute("data-view") || "main";

    const setView = () => {
      section.setAttribute("data-view", currentView);
      buttons.forEach((btn) => {
        btn.classList.toggle(
          "is-active",
          btn.getAttribute("data-view-btn") === currentView,
        );
      });
    };

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        currentView = btn.getAttribute("data-view-btn") || "main";
        setView();
      });
    });

    setView();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTabs);
  } else {
    initTabs();
  }
</script>
