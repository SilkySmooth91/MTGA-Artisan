---
import art1 from "../assets/art1.webp";

interface Props {
  title?: string;
  excerpt?: string;
  imageUrl?: string;
  href?: string;
}

const {
  title = "Titolo articolo",
  excerpt = "Breve estratto dell'articolo per dare contesto e invogliare alla lettura.",
  imageUrl = art1.src,
  href = "#",
} = Astro.props;
---

<article
  class="card w-full max-w-[455px] md:max-w-[860px] aspect-[455/297] md:aspect-[860/441] rounded-2xl"
>
  <a
    href={href}
    class="group relative block w-full h-full rounded-2xl overflow-hidden shadow-lg"
    style={`background-image: url('${imageUrl}'); background-size: cover; background-position: center;`}
    aria-label={title}
  >
    <div
      class="absolute inset-0 rounded-2xl bg-black/50 opacity-100 transition-opacity duration-200 ease-in-out group-hover:opacity-70"
      id="img-overlay"
    >
    </div>
    <div class="relative z-10 p-6 flex flex-col gap-3 text-text">
      <h3 class="text-xl font-heading font-medium leading-snug mb-3">
        {title}
      </h3>
      <p class="text-base font-body leading-normal text-white/90">
        {excerpt}
      </p>
    </div>
  </a>
</article>

<style>
  .card {
    color: var(--color-text);
    box-shadow: 0 0 10px var(--color-primary);
  }
</style>
