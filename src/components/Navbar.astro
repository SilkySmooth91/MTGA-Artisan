---
import { Image } from "astro:assets";
import MainButton from "./MainButton.astro";
import burgerIcon from "../assets/burger-menu-icon.svg";
import closeIcon from "../assets/icons/close_icon.svg";
import fireHammerLogo from "../assets/fire_hammer_logo.webp";
---

<div class="w-full md:shadow md:shadow-black/75">
  <nav class="navbar w-full max-w-screen-2xl mx-auto px-10 py-9">
    <!-- Mobile Layout -->
    <div class="md:hidden grid grid-cols-3 items-center">
      <!-- Burger Menu Button -->
      <div class="w-full flex justify-start items-center">
        <button
          class="burger-menu z-50 w-10 h-10 flex items-center justify-center"
          id="mobile-menu-button"
        >
          <img src={burgerIcon.src} alt="Menu" class="w-7 h-7" />
        </button>
      </div>
      <!-- Logo mobile -->
      <a
        href="/"
        class="navbar-logo justify-self-center flex items-center justify-center"
      >
        <Image
          src={fireHammerLogo}
          alt="MTGA Artisan Logo"
          width={72}
          height={72}
          class="h-10 w-10 mr-10"
          loading="eager"
          fetchpriority="high"
        />
      </a>
      <div class="w-full flex justify-end items-center">
        <MainButton href="#" class="py-3! px-4! text-xs! leading-none"
          >Community</MainButton
        >
      </div>
    </div>

    <!-- Desktop Layout -->
    <div
      class="navbar-container hidden md:grid grid-cols-[1fr_auto_1fr] items-center"
    >
      <ul
        class="navbar-menu flex justify-center items-center gap-10 text-[#B3B3B3]! text-xl col-start-2"
      >
        <li class="navbar-item">
          <a href="/" class="navbar-link">Inn</a>
        </li>
        <li class="navbar-item">
          <a href="/about" class="navbar-link">About</a>
        </li>
        <li class="navbar-item">
          <a href="/playArtisan" class="navbar-link">Play Artisan</a>
        </li>
        <li class="navbar-item">
          <a href="/" class="navbar-logo">
            <Image
              src={fireHammerLogo}
              alt="MTGA Artisan Logo"
              width={72}
              height={72}
              class="h-18 w-18"
              loading="eager"
              fetchpriority="high"
            />
          </a>
        </li>
        <li class="navbar-item">
          <a href="/news" class="navbar-link">News</a>
        </li>
        <li class="navbar-item">
          <a href="/comingSoon" class="navbar-link">Events</a>
        </li>
        <li class="navbar-item">
          <a href="/comingSoon" class="navbar-link">Rankings</a>
        </li>
      </ul>
      <div class="col-start-3 justify-self-end">
        <MainButton href="#" class="md:mr-5! text-xs! md:text-base"
          >Community</MainButton
        >
      </div>
    </div>
    <!-- Mobile Overlay Menu (hidden by default) -->
    <div
      class="mobile-menu-overlay invisible pointer-events-none md:hidden text-center w-45.25 h-82.25 bg-background/80 backdrop-blur-md rounded-xl absolute top-0 left-0 z-90 flex items-center justify-center opacity-0 scale-95 transition-all duration-200 ease-out"
      id="mobile-menu"
    >
      <button
        class="absolute top-4 right-4 bg-transparent"
        id="mobile-menu-close"
      >
        <img src={closeIcon.src} alt="Close Menu" class="w-5 h-5" />
      </button>
      <ul class="mobile-menu-list w-full px-5 pt-8 pb-4">
        <li class="navbar-item">
          <a href="/" class="navbar-link">Inn</a>
        </li>
        <li class="navbar-item">
          <a href="/about" class="navbar-link">About</a>
        </li>
        <li class="navbar-item">
          <a href="/playArtisan" class="navbar-link">Play Artisan</a>
        </li>
        <li class="navbar-item">
          <a href="/news" class="navbar-link">News</a>
        </li>
        <li class="navbar-item">
          <a href="/comingSoon" class="navbar-link">Events</a>
        </li>
        <li class="navbar-item">
          <a href="/comingSoon" class="navbar-link">Rankings</a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const closeButton = document.getElementById("mobile-menu-close");
    const enterClasses = ["opacity-100", "scale-100"];
    const leaveClasses = [
      "opacity-0",
      "scale-95",
      "invisible",
      "pointer-events-none",
    ];

    const openMenu = () => {
      if (!mobileMenu) {
        return;
      }

      mobileMenu.classList.remove(
        "invisible",
        "pointer-events-none",
        "opacity-0",
        "scale-95",
      );
      // Run on the next frame so transitions animate from the initial state.
      requestAnimationFrame(() => {
        mobileMenu.classList.add(...enterClasses);
      });
    };

    const closeMenu = () => {
      if (!mobileMenu || mobileMenu.classList.contains("invisible")) {
        return;
      }

      mobileMenu.classList.remove(...enterClasses);
      mobileMenu.classList.add(...leaveClasses);
    };

    menuButton?.addEventListener("click", () => {
      if (mobileMenu?.classList.contains("invisible")) {
        openMenu();
        return;
      }

      closeMenu();
    });

    closeButton?.addEventListener("click", () => {
      closeMenu();
    });
  });
</script>

<style>
  #mobile-menu {
    box-shadow: 0 5px 15px 2px var(--color-primary);
  }

  @media (max-width: 767px) {
    .mobile-menu-list .navbar-item {
      margin-bottom: 1.3rem;
      font-size: 1rem;
      line-height: 1.2;
    }

    .mobile-menu-list .navbar-item:last-child {
      margin-bottom: 0;
    }
  }
</style>
