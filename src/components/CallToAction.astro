---
import SecondaryButton from "./SecondaryButton.astro";
---

<section
  class="w-full max-w-screen-2xl mx-auto mt-36 mb-20 flex flex-col md:flex-row items-center justify-between py-8 md:px-20"
  id="call-to-action"
>
  <div class="mb-20 md:mb-0">
    <h1
      class="text-text text-center md:text-left font-heading text-5xl leading-18"
    >
      More Strategy. <br />
      Less Rarity.
    </h1>
  </div>
  <div class="flex items-center justify-between space-x-14 md:space-x-20">
    <SecondaryButton>Join Us</SecondaryButton>
    <SecondaryButton>Support Us</SecondaryButton>
  </div>
</section>
